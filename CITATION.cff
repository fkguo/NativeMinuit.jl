license: LGPL-2.1-or-later
version: 0.3.0
date-released: "2026-05-31"
keywords:
  - Julia
  - Minuit
  - Minuit2
  - function minimization
  - chi-square fit
  - maximum likelihood
  - high-energy physics
references:
